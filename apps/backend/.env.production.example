# =====================================================
# Beacon — Produção (.env.production)
# Copie este arquivo: cp .env.production.example .env.production
# =====================================================

# Database — Supabase (mesma do dev, ou crie um projeto dedicado)
DATABASE_URL="postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres?sslmode=require"

# Redis — local via Docker (configurado no docker-compose.prod.yml)
# Não precisa configurar aqui — REDIS_HOST e REDIS_PORT são injetados pelo docker-compose
# Se quiser usar Upstash: descomente a linha abaixo e comente as vars no docker-compose
# REDIS_URL="rediss://default:SUA_SENHA@SEU_HOST.upstash.io:6379"

# Qdrant (se usar busca vetorial — pode deixar vazio por ora)
QDRANT_URL=http://localhost:6333

# JWT — TROQUE estes valores em produção!
JWT_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA
JWT_REFRESH_SECRET=TROQUE_POR_OUTRA_STRING_ALEATORIA_LONGA
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Single-tenant
DEFAULT_TENANT_ID=c06cd73f-c4ae-495f-9c5e-cce309e58244

# App
PORT=3000
NODE_ENV=production

# ⚠️  IMPORTANTE: URL pública da VPS (sem barra no final)
# Se tiver domínio:  BEACON_PUBLIC_URL=https://beacon.seudominio.com
# Se for só IP:      BEACON_PUBLIC_URL=http://IP_DA_SUA_VPS
BEACON_PUBLIC_URL=http://IP_DA_SUA_VPS
